<Window x:Class="MDViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="MDViewer"
        Height="900" Width="1000"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="MinWidth" Value="36"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8E8E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="6,4">
            <DockPanel>
                <!-- Left side: File operations -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Style="{StaticResource ToolbarButton}" Click="OpenFile_Click"
                            ToolTip="Open file (Ctrl+O)">
                        <TextBlock Text="📂 Open" FontSize="13"/>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Click="Print_Click"
                            ToolTip="Print (Ctrl+P)" x:Name="PrintButton" IsEnabled="False">
                        <TextBlock Text="🖨️ Print" FontSize="13"/>
                    </Button>
                    <Rectangle Width="1" Fill="#CCCCCC" Margin="8,2"/>
                </StackPanel>

                <!-- Right side: Zoom controls -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource ToolbarButton}" Click="ZoomOut_Click"
                            ToolTip="Zoom out (Ctrl+-)" x:Name="ZoomOutButton" IsEnabled="False">
                        <TextBlock Text="➖" FontSize="12"/>
                    </Button>
                    <TextBlock x:Name="ZoomLabel" Text="100%"
                               VerticalAlignment="Center" Margin="6,0"
                               FontSize="13" MinWidth="40" TextAlignment="Center"/>
                    <Button Style="{StaticResource ToolbarButton}" Click="ZoomIn_Click"
                            ToolTip="Zoom in (Ctrl++)" x:Name="ZoomInButton" IsEnabled="False">
                        <TextBlock Text="➕" FontSize="12"/>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Click="ZoomReset_Click"
                            ToolTip="Reset zoom (Ctrl+0)" x:Name="ZoomResetButton" IsEnabled="False">
                        <TextBlock Text="↺ 100%" FontSize="12"/>
                    </Button>
                </StackPanel>

                <!-- Center: File name -->
                <TextBlock x:Name="FileNameLabel" Text="No file open"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontSize="13" Foreground="#666666"
                           TextTrimming="CharacterEllipsis" Margin="8,0"/>
            </DockPanel>
        </Border>

        <!-- WebView2 Content -->
        <wv2:WebView2 Grid.Row="1" x:Name="WebView"
                      DefaultBackgroundColor="Transparent"/>

        <!-- Status Bar -->
        <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Padding="8,3">
            <TextBlock x:Name="StatusLabel" Text="Ready"
                       FontSize="11" Foreground="#888888"/>
        </Border>
    </Grid>
</Window>
