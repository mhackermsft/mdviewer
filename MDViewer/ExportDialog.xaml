<Window x:Class="MDViewer.ExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        MinWidth="380">
    <StackPanel Margin="24,20,24,20">
        <TextBlock Text="Export Options" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <!-- Format selection -->
        <TextBlock Text="Format" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <RadioButton x:Name="FormatPdf" Content="PDF" GroupName="Format"
                     IsChecked="True" FontSize="13" Margin="4,0,0,4"/>
        <RadioButton x:Name="FormatHtml" Content="HTML (standalone, scrollable)"
                     GroupName="Format" FontSize="13" Margin="4,0,0,12"/>

        <!-- Linked docs option (hidden when no linked docs) -->
        <StackPanel x:Name="LinkedDocsPanel" Margin="0,0,0,4">
            <CheckBox x:Name="IncludeLinkedDocsCheckBox"
                      FontSize="13" Margin="0,0,0,4" IsChecked="True"/>
            <TextBlock x:Name="LinkedDocsInfo"
                       FontSize="12" Foreground="#888888"
                       Margin="22,0,0,8" TextWrapping="Wrap"/>
        </StackPanel>

        <Separator Margin="0,8,0,16"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Export"
                    MinWidth="80" Height="28"
                    Margin="0,0,8,0" Padding="12,0"
                    IsDefault="True"
                    Click="Export_Click"/>
            <Button Content="Cancel"
                    MinWidth="80" Height="28"
                    Padding="12,0"
                    IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
